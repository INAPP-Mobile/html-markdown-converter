{
  "name": "html-markdown-converter",
  "version": "1.0.0",
  "description": "A template for converting HTML to Markdown using TypeScript and Node.js, deployable on Railway",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prepare": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "html",
    "markdown",
    "converter",
    "typescript",
    "nodejs",
    "railway"
  ],
  "author": "INAPP-Mobile",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "marked": "^12.0.0",
    "turndown": "^7.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.5.0",
    "@types/supertest": "^7.2.0",
    "@types/turndown": "^5.0.6",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
